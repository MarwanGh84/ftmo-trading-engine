# Copy to ~/trading/.env and fill in. Keep .env chmod 600. Never commit real values.
# Telegram (from @BotFather + your chat_id). Leave blank to run without reporting.
TELEGRAM_TOKEN=
TELEGRAM_CHAT_ID=

# Execution arming. MUST stay false until a clean supervised dry run is reviewed.
# When false the engine validates and sizes but logs "WOULD PLACE" instead of sending orders.
ARMED=false

# Google Sheets live dashboard (see SETUP_SHEETS.md). Leave blank to disable.
GOOGLE_SA_JSON=
GSHEET_ID=
