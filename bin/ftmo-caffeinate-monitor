#!/usr/bin/env python3
"""Caffeinate watchdog — ensures the Mac never sleeps during trading hours.
Runs every 5 min via launchd. If caffeinate has died, restarts it and Telegrams.
"""
import subprocess
import sys
from pathlib import Path

ROOT = Path(__file__).resolve().parent.parent
sys.path.insert(0, str(ROOT))

from engine import config, telegram
from engine import state as state_mod

# Only check during active hours (no need to keep the Mac awake overnight)
now = state_mod.now_dubai()
if now.weekday() >= 5 or not (config.SCAN_HOURS_DUBAI[0] - 1 <= now.hour < config.SCAN_HOURS_DUBAI[1] + 1):
    sys.exit(0)

result = subprocess.run(["pgrep", "-x", "caffeinate"], capture_output=True, text=True)
if result.returncode == 0:
    sys.exit(0)   # running fine

# caffeinate has died — restart it
try:
    subprocess.Popen(["caffeinate", "-dimsu"], close_fds=True)
    telegram.send("⚠️ caffeinate process was dead — restarted. Mac was at risk of sleeping during trading hours. "
                  "Check System Settings > Battery if this recurs.")
except Exception as e:
    telegram.send(f"⚠️ caffeinate restart FAILED: {e}. Mac may sleep — check immediately.")
